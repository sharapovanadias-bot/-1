{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "resolveJsonModule": true
  },
  "include": ["src/**/*.ts", "api/**/*.ts", "models/**/*.ts", "controllers/**/*.ts", "utils/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
